# openclaw-claude-bridge environment variables
# Copy this file to .env and fill in your values

# Optional: Claude CLI model aliases (always points to latest version)
# Change to opus[1m] / sonnet[1m] when 1M context window variants become available
# OPUS_MODEL=opus
# SONNET_MODEL=sonnet
# HAIKU_MODEL=haiku

# Optional: idle timeout — kill Claude CLI if no activity for this long (default 2 min)
# Requests with active tool calls will never be killed regardless of total duration.
# IDLE_TIMEOUT_MS=120000

# Optional: override default ports
# OPENCLAW_BRIDGE_PORT=3456
# OPENCLAW_BRIDGE_STATUS_PORT=3458

# Optional: path to Claude Code CLI binary (if not in PATH)
# CLAUDE_BIN=/home/youruser/.local/bin/claude

# Recommended: dashboard password (HTTP Basic Auth, user: admin)
# The dashboard (port 3458) is accessible on your local network.
# Without a password, anyone on the same network can view request history,
# agent names, token usage, and costs. Set this if you're on a shared network.
DASHBOARD_PASS=change_me
