# openclaw-claude-bridge environment variables
# Copy this file to .env and fill in your values

# Optional: Claude CLI model overrides for explicit exposed model ids
# Change to claude-opus-4-6[1m] / claude-sonnet-4-6[1m] when 1M variants are available
# OPUS_MODEL=claude-opus-4-6
# OPUS_47_MODEL=claude-opus-4-7
# SONNET_MODEL=claude-sonnet-4-6
# HAIKU_MODEL=claude-haiku-4-5

# Optional: idle timeout — kill Claude CLI if no activity for this long (default 2 min)
# Requests with active tool calls will never be killed regardless of total duration.
# IDLE_TIMEOUT_MS=120000

# Optional: override default ports
# OPENCLAW_BRIDGE_PORT=3456
# OPENCLAW_BRIDGE_STATUS_PORT=3458

# Optional: status/dashboard bind interface.
# Default 127.0.0.1 (loopback only). Set to 0.0.0.0 to expose on LAN.
# DASHBOARD_PASS is required when binding to a non-loopback interface.
# OPENCLAW_BRIDGE_STATUS_BIND=127.0.0.1

# Optional: dashboard dev server proxy target for status/cleanup API calls.
# Defaults to local status API. Set only when developing the dashboard against a
# remote bridge status server. For Vite dev, put this in dashboard/.env or export it.
# VITE_STATUS_API_TARGET=http://127.0.0.1:3458

# Optional: path to Claude Code CLI binary (if not in PATH)
# CLAUDE_BIN=/home/youruser/.local/bin/claude

# Optional: pass Claude CLI --dangerously-skip-permissions.
# Default disabled. Only enable in a trusted local sandbox.
# OPENCLAW_BRIDGE_CLAUDE_SKIP_PERMISSIONS=1

# Optional: attachment behavior and limits.
# passthrough is the default native multimodal mode. Set to describe to drop non-text
# attachment parts and preserve historical imageModel-style behavior.
# OPENCLAW_BRIDGE_ATTACHMENT_MODE=passthrough
# Max non-text attachment parts accepted per turn.
# OPENCLAW_BRIDGE_ATTACHMENT_PER_TURN_CAP=20
# Attachment staging/state disk budget in megabytes.
# OPENCLAW_BRIDGE_ATTACHMENT_SESSION_BUDGET_MB=500
# Remote http(s) attachment download timeout in milliseconds.
# OPENCLAW_BRIDGE_ATTACHMENT_DOWNLOAD_TIMEOUT_MS=30000
# Max remote attachment download size in bytes (default 50 MiB).
# OPENCLAW_BRIDGE_ATTACHMENT_DOWNLOAD_MAX_BYTES=52428800
# Attachment staging directory defaults to repo ./state when unset.
# OPENCLAW_BRIDGE_STATE_DIR=./state

# Optional: local file attachment root allowlist.
# Default empty/unset rejects local file attachment paths; data: and http(s) attachments are unaffected.
# Use colon-separated root directories; ~ is supported.
# OPENCLAW_BRIDGE_ATTACHMENT_ROOTS=~/Downloads:/Users/you/Pictures

# Recommended: dashboard password (HTTP Basic Auth, user: admin).
# By default the dashboard is bound to localhost only, so a password is
# optional. Setting it also enables the /cleanup endpoint, which deletes
# Claude CLI sessions and is disabled when no password is set.
# Required whenever OPENCLAW_BRIDGE_STATUS_BIND is non-loopback.
DASHBOARD_PASS=change_me
